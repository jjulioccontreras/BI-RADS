"""
Description
Mammography is one of the most effective tools for the early detection of breast cancer. Radiologists describe mammographic findings in structured narrative reports, and assign a BI-RADS® (Breast Imaging Reporting and Data System) category to indicate the level of suspicion for malignancy and the recommended clinical management.

The objective is to  develop models that predict the BI-RADS classification given the mammography report text, excluding the impression/conclusion section. The goal is to teach models to infer the underlying diagnostic reasoning from the descriptive content of the report — simulating a system that can classify cases based on textual findings alone.

What is BI-RADS?
The Breast Imaging Reporting and Data System (BI-RADS) was developed by the American College of Radiology (ACR) to standardize mammography reporting and reduce ambiguity between radiologists and referring clinicians. The BI-RADS category reflects both imaging appearance and clinical context, ranging from negative exams to confirmed malignancies.

The standard BI-RADS categories are:

Category	Description	Typical Management
0	Incomplete – Need additional imaging evaluation	Recall for additional imaging
1	Negative	Routine screening
2	Benign finding(s)	Routine screening
3	Probably benign	Short-interval follow-up suggested
4	Suspicious abnormality	Consider biopsy
5	Highly suggestive of malignancy	Appropriate action should be taken
6	Known biopsy-proven malignancy	Surgical or oncologic treatment
Reference: https://www.acr.org/Clinical-Resources/Clinical-Tools-and-Reference/Reporting-and-Data-Systems/BI-RADS

The Challenge
Your task is to predict the BI-RADS category for each mammogram exam using only the text of the radiology report (excluding the impression section).

Each report includes descriptive findings such as breast composition, presence of calcifications or masses, asymmetries, and associated features. The impression or assessment section — which explicitly contains the BI-RADS category — has been removed to ensure the model must reason from the findings themselves.

Participants will receive a training set of reports with their corresponding BI-RADS labels and a test set without labels. Your model should output a predicted BI-RADS category for each test report.

Why This Matters
Predicting BI-RADS from descriptive findings is a step toward developing decision-support systems that can:

Assist radiologists in maintaining consistency across reports
Enable automated quality control of breast imaging reports
Provide educational feedback for trainees
Support large-scale research in breast imaging and natural language processing (NLP)
"""
import warnings
 
warnings.filterwarnings('ignore')
import pandas as pd
import numpy as np
print("Pr-2026-mammography-report-classification started")
import re
import warnings
from sklearn.feature_extraction.text import TfidfVectorizer
from sklearn.svm import LinearSVC
from sklearn.naive_bayes import MultinomialNB
from sklearn.linear_model import LogisticRegression
from sklearn.linear_model import RidgeClassifierCV
from sklearn.ensemble import AdaBoostClassifier 
from sklearn.ensemble import VotingClassifier
from sklearn.calibration import CalibratedClassifierCV
from sklearn.model_selection import StratifiedKFold, cross_val_score
from nltk.corpus import stopwords
import nltk

warnings.filterwarnings('ignore')

print("# --- 1. Resources & Data ---")
nltk.download('stopwords', quiet=True)
PT_STOPS = stopwords.words('portuguese')

train = pd.read_csv('/kaggle/input/competitions/spr-2026-mammography-report-classification/train.csv')
test = pd.read_csv('/kaggle/input/competitions/spr-2026-mammography-report-classification/test.csv')

def clean_text(text):
    text = str(text).lower()
    text = re.sub(r'[^\w\s\.]', ' ', text)
    text = re.sub(r'\s+', ' ', text).strip()
    return text

train['report_clean'] = train['report'].apply(clean_text)
test['report_clean'] = test['report'].apply(clean_text)

print("# --- 2. Heavy-Duty Vectorization ---")
# We use a broad range to catch specific medical bigrams and trigrams
vectorizer = TfidfVectorizer(
    stop_words=PT_STOPS,
    ngram_range=(1, 3),
    max_features=20000, 
    sublinear_tf=True,
    strip_accents='unicode'
)

X_train = vectorizer.fit_transform(train['report_clean'])
X_test = vectorizer.transform(test['report_clean'])
y_train = train['target']

print("# --- 3. The Ensemble (The Path to 1.0) ---")

# Model A: Linear SVC (The Precision Model)
svc = CalibratedClassifierCV(LinearSVC(C=1.0, class_weight='balanced', random_state=42))

# Model B: Logistic Regression (The Balanced Model)
log_reg = LogisticRegression(C=10, solver='lbfgs', multi_class='multinomial', max_iter=1000)

# Model C: MultinomialNB (The Word-Frequency Model)
nb = MultinomialNB(alpha=0.01)
#
#rid = RidgeClassifierCV(alphas=[1e-3, 1e-2, 1e-1, 1])
ada = AdaBoostClassifier(n_estimators=100, random_state=0)
# Create the Ensemble
ensemble = VotingClassifier(
    estimators=[
        ('svc', svc),
        ('lr', log_reg),
        ('nb', nb),
        ('ada', ada)
    ],
    voting='soft'  # 'soft' uses probabilities for the vote, which is more accurate
)

print("# --- 4. Cross-Validation & Training ---")
cv = StratifiedKFold(n_splits=10, shuffle=True, random_state=42)
cv_scores = cross_val_score(ensemble, X_train, y_train, cv=cv)

print(f"Ensemble CV Accuracy: {cv_scores.mean():.4f}")

ensemble.fit(X_train, y_train)

print("# --- 5. Hard-Coded Clinical Logic (The Final Filter) ---")
def apply_clinical_rules(df):
    """Override model predictions with absolute clinical certainty."""
    # BI-RADS 6: Existing biopsy-proven cancer
    p6 = r'carcinoma|maligna|cdis|grau iii|infiltrante'
    df.loc[df['report'].str.contains(p6, case=False, na=False), 'target'] = 6
    
    # BI-RADS 5: Highly suggestive
    p5 = r'espiculad.*distorç|distorç.*espiculad|nódulo denso irregular'
    df.loc[df['report'].str.contains(p5, case=False, na=False), 'target'] = 5
    
    # BI-RADS 2: Findings like 'cistos simples' or 'prótese' are always benign
    p2 = r'cisto simples|prótese|calcificações grosseiras'
    mask_2 = (df['report'].str.contains(p2, case=False, na=False)) & (df['target'] > 2)
    df.loc[mask_2, 'target'] = 2
    
    return df

print("# --- 6. Prediction & Submission ---")
test['target'] = ensemble.predict(X_test)
test = apply_clinical_rules(test)

submission = test[['ID', 'target']]
submission.to_csv('submission.csv', index=False)
print(submission.head())
print(submission.shape)
print("End program")
 
